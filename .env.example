# ============================================================================
# Clés de streaming - Configuration
# ============================================================================
# SÉCURITÉ : Copier ce fichier vers .env et remplir avec vos vraies clés
#            NE JAMAIS commiter .env dans Git !
#            Permissions recommandées : chmod 600 .env
# ============================================================================

# Clés de stream des plateformes
TWITCH_KEY=live_XXXXXXXXXXXX
YOUTUBE_KEY=xxxx-xxxx-xxxx-xxxx-xxxx
X_KEY=xxxxxxxxxxxx
FACEBOOK_KEY=FB-XXXXXXXXXXXX-0-XXXXXXXXXXXXXX
PEERTUBE_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Nom du stream (utilisé pour l'URL OBS → rtmp://[IP]:1935/live/[STREAM_NAME])
STREAM_NAME=radiocausecommune

# Configuration réseau
RTMP_SERVER_IP=192.168.10.108

# Domaine pour le CORS (utilisé dans nginx.conf.template)
CORS_DOMAIN=https://rtmp.causecommune.fm

# Sous-titres IA (Voxtral via Socket.IO) — laisser vide pour désactiver
VOXTRAL_URL=http://192.168.x.x:5004

# ============================================================================
# Intégration YouTube Live Streaming API (optionnel)
# ============================================================================
# 1. Créer un projet sur https://console.cloud.google.com
# 2. Activer l'API "YouTube Data API v3"
# 3. Créer des identifiants OAuth 2.0 (type "Application Web")
# 4. Ajouter l'URI de redirection : https://[votre-domaine]/api/broadcast/youtube/callback
# 5. Renseigner les valeurs ci-dessous puis visiter /api/broadcast/youtube/auth-url
YOUTUBE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Intégration Twitch Helix API (optionnel)
# ============================================================================
# 1. Créer une application sur https://dev.twitch.tv/console
# 2. Ajouter l'URI de redirection : https://[votre-domaine]/api/broadcast/twitch/callback
# 3. Renseigner les valeurs ci-dessous puis visiter /api/broadcast/twitch/auth-url
TWITCH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL publique pour les callbacks OAuth (sans slash final)
# Exemple : https://rtmp.causecommune.fm
OAUTH_CALLBACK_BASE=https://rtmp.causecommune.fm
